    {
      "name": "Admin APIs",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{access_token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "POST Ask AI",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What is the current system status?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/ask-ai",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "ask-ai"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"AI response received\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('question');",
                  "    pm.expect(jsonData).to.have.property('answer');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
